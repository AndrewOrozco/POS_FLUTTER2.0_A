# =============================================================
# TERPEL POS - Configuración de entorno
# =============================================================
# Copia este archivo como .env y ajusta los valores según
# la instalación. NO subir a git (agregar .env al .gitignore)
# =============================================================

# --- Backend Python FastAPI (api-consultas-flutter) ---
# Corre localmente en este mismo equipo
HOST_CONSULTAS=192.168.1.15
PORT_CONSULTAS=8020 

# --- LazoExpress Java/Node (surtidores, movimientos) ---
# Puede estar en otro equipo de la red
HOST_LAZOEXPRESS=192.168.1.15
PORT_LAZOEXPRESS=8010

# --- Flask / Socket.IO (Status Pump - estado surtidores) ---
# Puede estar en otro equipo de la red
HOST_FLASK=192.168.1.15
PORT_FLASK=5000

# --- Orquestador de Pagos (APP TERPEL, GoPass) ---
# Puede estar en otro equipo de la red
HOST_PAGOS=192.168.1.15
PORT_PAGOS=5555
